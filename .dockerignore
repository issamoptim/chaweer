# ==========================================================
# Chaweer - .dockerignore
# ==========================================================

# Dépendances (réinstallées dans le container)
node_modules/
**/node_modules/

# Build outputs
dist/
**/dist/
build/
coverage/

# Environnement (jamais dans l'image)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Git
.git/
.gitignore

# Logs
*.log
logs/

# Cache
.turbo/
.vite/
.cache/
.parcel-cache/

# TypeScript
*.tsbuildinfo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/

# Temporaire
tmp/
temp/
.tmp/

# Tests
playwright-report/
test-results/
