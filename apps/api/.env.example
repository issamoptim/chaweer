PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/chaweer"
DATABASE_TEST_URL="postgresql://user:password@localhost:5432/chaweer_test"

# Auth — JWT
JWT_SECRET="change-me-in-production-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS=30
JWT_ISSUER="chaweer-api"

# Auth — Cookies
COOKIE_NAME="refresh_token"
COOKIE_SECURE=false
COOKIE_SAME_SITE="lax"
COOKIE_PATH="/auth"
# COOKIE_DOMAIN=  # Set in production (e.g. .chaweer.ma), leave empty for localhost

# CORS — Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173"

# Auth — Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:5173/auth/google/callback"
