PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chaweer"
DATABASE_TEST_URL="postgresql://postgres:postgres@localhost:5432/chaweer_test"

# Auth — JWT
JWT_SECRET="dev-jwt-secret-at-least-32-characters-long!!"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_DAYS=30
JWT_ISSUER="chaweer-api"

# Auth — Cookies
COOKIE_NAME="refresh_token"
COOKIE_SECURE=false
COOKIE_SAME_SITE="lax"
COOKIE_PATH="/auth"

# Auth — Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="postmessage"
