# ==========================================================
# Chaweer - Global .gitignore
# ==========================================================

# -------------------------
# Dependencies
# -------------------------
node_modules/

# -------------------------
# Build outputs
# -------------------------
dist/
build/
coverage/
.next/
out/
.expo/
.expo-shared/

# -------------------------
# Vite / Turbo / Cache
# -------------------------
.vite/
.turbo/
.cache/
.parcel-cache/

# -------------------------
# TypeScript
# -------------------------
*.tsbuildinfo

# -------------------------
# Logs
# -------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -------------------------
# Environment
# -------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Keep examples
!.env.example

# -------------------------
# Prisma
# -------------------------
prisma/dev.db
prisma/dev.db-journal

# -------------------------
# macOS
# -------------------------
.DS_Store
.AppleDouble
.LSOverride

# -------------------------
# Linux
# -------------------------
*~

# -------------------------
# Windows
# -------------------------
Thumbs.db
Desktop.ini

# -------------------------
# IDE
# -------------------------
.vscode/
.idea/
*.iml

# Vim
*.swp
*.swo

# -------------------------
# Temporary
# -------------------------
tmp/
temp/
.tmp/

# -------------------------
# Test reports
# -------------------------
playwright-report/
test-results/

# -------------------------
# npm
# -------------------------
.npm/

# -------------------------
# Misc
# -------------------------
*.pid
*.seed
*.pid.lock